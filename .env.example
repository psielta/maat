# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:14500

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:14500
NEXTAUTH_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://taxonomy:taxonomy@localhost:14532/taxonomy?schema=public"

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
EMAIL_FROM="Taxonomy <noreply@example.com>"

# Development email uses MailHog through SMTP.
SMTP_HOST=localhost
SMTP_PORT=14525
SMTP_USER=
SMTP_PASSWORD=

# Production email uses Resend.
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Subscriptions (Stripe)
# -----------------------------------------------------------------------------
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PLAN_ID=
