# ============================================================================
# Maat — modelo de .env de PRODUCAO (VPS compartilhado, /opt/maat/.env)
# Copie para .env, preencha os segredos e rode `chmod 600 .env`.
# NUNCA commite o .env real. Gere segredos no servidor:
#   openssl rand -hex 32   (NEXTAUTH_SECRET)
#   openssl rand -hex 24   (senhas — use valores URL-safe, sem @ : / # ?)
# ============================================================================

# --- App / URLs publicas ---
NEXT_PUBLIC_APP_URL=https://maat.mateussalgueiro.com.br
NEXTAUTH_URL=https://maat.mateussalgueiro.com.br
NEXTAUTH_SECRET=CHANGE_ME_openssl_rand_hex_32

# --- PostgreSQL (interno, rede maat-net) ---
POSTGRES_USER=maat
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_24
POSTGRES_DB=maat
# DATABASE_URL precisa bater com POSTGRES_* acima e apontar para o container.
DATABASE_URL=postgresql://maat:CHANGE_ME_openssl_rand_hex_24@maat-postgres:5432/maat?schema=public

# --- Redis (interno, realtime Pub/Sub + SSE) ---
REDIS_URL=redis://maat-redis:6379

# --- E-mail (Resend; dominio mateussalgueiro.com.br verificado) ---
EMAIL_FROM=Maat <noreply@mateussalgueiro.com.br>
RESEND_API_KEY=CHANGE_ME_re_xxxxxxxx
# SMTP_* sao exigidos pelo schema do env.mjs mas NAO sao usados em producao
# (em prod o envio vai por Resend). Placeholders bastam.
SMTP_HOST=localhost
SMTP_PORT=25

# --- Object storage (MinIO interno, exposto por /maat-uploads via Caddy) ---
MINIO_ROOT_USER=maat
MINIO_ROOT_PASSWORD=CHANGE_ME_openssl_rand_hex_24
# S3_* sao as credenciais que o app usa (precisam ser iguais as do MinIO root).
S3_ENDPOINT=https://maat.mateussalgueiro.com.br
S3_ACCESS_KEY=maat
S3_SECRET_KEY=CHANGE_ME_openssl_rand_hex_24
S3_BUCKET=maat-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
