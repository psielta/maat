// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map(name: "created_at")
  updatedAt         DateTime @default(now()) @map(name: "updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map(name: "accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map(name: "sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now()) @map(name: "created_at")
  updatedAt     DateTime  @default(now()) @map(name: "updated_at")

  accounts Account[]
  sessions Session[]
  boards   Board[]
  boardMemberships BoardMember[]
  boardEvents      BoardEvent[]
  cardComments     BoardCardComment[]
  cardAttachments  BoardCardAttachment[]
  notifications      Notification[] @relation("NotificationUser")
  actedNotifications Notification[] @relation("NotificationActor")

  @@map(name: "users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map(name: "verification_tokens")
}

model Board {
  id            String      @id @default(cuid())
  title         String
  description   String?
  cardIdPattern String?     @map(name: "card_id_pattern")
  createdAt     DateTime    @default(now()) @map(name: "created_at")
  updatedAt     DateTime    @updatedAt @map(name: "updated_at")
  authorId      String      @map(name: "author_id")
  lists         BoardList[]
  members       BoardMember[]
  events        BoardEvent[]
  cardIdSequences BoardCardIdSequence[]
  customFields  BoardCustomField[]
  labels        BoardLabel[]

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@map(name: "boards")
}

enum BoardMemberRole {
  OWNER
  EDITOR
  VIEWER
}

model BoardMember {
  id        String          @id @default(cuid())
  role      BoardMemberRole @default(EDITOR)
  createdAt DateTime        @default(now()) @map(name: "created_at")
  updatedAt DateTime        @updatedAt @map(name: "updated_at")
  boardId   String          @map(name: "board_id")
  userId    String          @map(name: "user_id")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
  @@map(name: "board_members")
}

model BoardList {
  id        String      @id @default(cuid())
  title     String
  order     Int         @default(0) @map(name: "sort_order")
  createdAt DateTime    @default(now()) @map(name: "created_at")
  updatedAt DateTime    @updatedAt @map(name: "updated_at")
  boardId   String      @map(name: "board_id")
  cards     BoardCard[]

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@map(name: "board_lists")
}

model BoardCard {
  id          String    @id @default(cuid())
  displayId   String?   @map(name: "display_id")
  title       String
  description String?   @db.Text
  startDate   DateTime? @db.Date @map(name: "start_date")
  dueAt       DateTime? @map(name: "due_at")
  dueComplete Boolean   @default(false) @map(name: "due_complete")
  order       Int       @default(0) @map(name: "sort_order")
  archivedAt  DateTime? @map(name: "archived_at")
  createdAt   DateTime  @default(now()) @map(name: "created_at")
  updatedAt   DateTime  @updatedAt @map(name: "updated_at")
  listId      String    @map(name: "list_id")

  list              BoardList                    @relation(fields: [listId], references: [id], onDelete: Cascade)
  comments          BoardCardComment[]
  attachments       BoardCardAttachment[]
  customFieldValues BoardCardCustomFieldValue[]
  labels            BoardCardLabel[]
  checklists        BoardCardChecklist[]

  @@index([listId])
  @@index([listId, archivedAt])
  @@index([displayId])
  @@index([dueAt])
  @@map(name: "board_cards")
}

model BoardCardIdSequence {
  id         String   @id @default(cuid())
  dateKey    String   @default("") @map(name: "date_key")
  lastNumber Int      @default(0) @map(name: "last_number")
  createdAt  DateTime @default(now()) @map(name: "created_at")
  updatedAt  DateTime @updatedAt @map(name: "updated_at")
  boardId    String   @map(name: "board_id")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, dateKey])
  @@map(name: "board_card_id_sequences")
}

model BoardCardComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
  cardId    String   @map(name: "card_id")
  authorId  String   @map(name: "author_id")

  card        BoardCard             @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author      User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments BoardCardAttachment[]

  @@index([cardId, createdAt])
  @@index([authorId])
  @@map(name: "board_card_comments")
}

enum BoardAttachmentStatus {
  PENDING
  READY
}

enum BoardAttachmentScope {
  CARD
  COMMENT
  INLINE
}

model BoardCardAttachment {
  id           String                @id @default(cuid())
  fileName     String                @map(name: "file_name")
  mimeType     String                @map(name: "mime_type")
  sizeBytes    BigInt                @map(name: "size_bytes")
  storageKey   String                @unique @map(name: "storage_key")
  scope        BoardAttachmentScope  @default(CARD)
  status       BoardAttachmentStatus @default(PENDING)
  createdAt    DateTime              @default(now()) @map(name: "created_at")
  updatedAt    DateTime              @updatedAt @map(name: "updated_at")
  cardId       String                @map(name: "card_id")
  commentId    String?               @map(name: "comment_id")
  uploadedById String                @map(name: "uploaded_by_id")

  card       BoardCard         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  comment    BoardCardComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploadedBy User              @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
  @@index([commentId])
  @@map(name: "board_card_attachments")
}

model Notification {
  id        String    @id @default(cuid())
  type      String
  data      Json
  readAt    DateTime? @map(name: "read_at")
  createdAt DateTime  @default(now()) @map(name: "created_at")
  userId    String    @map(name: "user_id")
  actorId   String?   @map(name: "actor_id")

  user  User  @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map(name: "notifications")
}

enum BoardCustomFieldType {
  TEXT
  NUMBER
  CHECKBOX
  DATE
  DROPDOWN
}

model BoardCustomField {
  id          String               @id @default(cuid())
  name        String
  type        BoardCustomFieldType
  order       Int                  @default(0) @map(name: "sort_order")
  showOnFront Boolean              @default(false) @map(name: "show_on_front")
  createdAt   DateTime             @default(now()) @map(name: "created_at")
  updatedAt   DateTime             @updatedAt @map(name: "updated_at")
  boardId     String               @map(name: "board_id")

  board   Board                        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  options BoardCustomFieldOption[]
  values  BoardCardCustomFieldValue[]

  @@index([boardId])
  @@map(name: "board_custom_fields")
}

model BoardCustomFieldOption {
  id        String   @id @default(cuid())
  label     String
  color     String
  order     Int      @default(0) @map(name: "sort_order")
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
  fieldId   String   @map(name: "field_id")

  field  BoardCustomField            @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  values BoardCardCustomFieldValue[]

  @@index([fieldId])
  @@map(name: "board_custom_field_options")
}

model BoardCardCustomFieldValue {
  id          String    @id @default(cuid())
  textValue   String?   @map(name: "text_value")
  numberValue Float?    @map(name: "number_value")
  dateValue   DateTime? @map(name: "date_value") @db.Date
  boolValue   Boolean?  @map(name: "bool_value")
  createdAt   DateTime  @default(now()) @map(name: "created_at")
  updatedAt   DateTime  @updatedAt @map(name: "updated_at")
  cardId      String    @map(name: "card_id")
  fieldId     String    @map(name: "field_id")
  optionId    String?   @map(name: "option_id")

  card   BoardCard               @relation(fields: [cardId], references: [id], onDelete: Cascade)
  field  BoardCustomField        @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  option BoardCustomFieldOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([cardId, fieldId])
  @@index([cardId])
  @@index([fieldId])
  @@map(name: "board_card_custom_field_values")
}

model BoardLabel {
  id        String   @id @default(cuid())
  name      String   @default("")
  color     String
  order     Int      @default(0) @map(name: "sort_order")
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
  boardId   String   @map(name: "board_id")

  board Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards BoardCardLabel[]

  @@index([boardId])
  @@map(name: "board_labels")
}

model BoardCardLabel {
  cardId  String @map(name: "card_id")
  labelId String @map(name: "label_id")

  card  BoardCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label BoardLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
  @@map(name: "board_card_labels")
}

model BoardCardChecklist {
  id        String   @id @default(cuid())
  title     String   @default("Checklist")
  order     Int      @default(0) @map(name: "sort_order")
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
  cardId    String   @map(name: "card_id")

  card  BoardCard                @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items BoardCardChecklistItem[]

  @@index([cardId])
  @@map(name: "board_card_checklists")
}

model BoardCardChecklistItem {
  id          String   @id @default(cuid())
  text        String
  isComplete  Boolean  @default(false) @map(name: "is_complete")
  order       Int      @default(0) @map(name: "sort_order")
  createdAt   DateTime @default(now()) @map(name: "created_at")
  updatedAt   DateTime @updatedAt @map(name: "updated_at")
  checklistId String   @map(name: "checklist_id")

  checklist BoardCardChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map(name: "board_card_checklist_items")
}

model BoardEvent {
  id        Int      @id @default(autoincrement())
  action    String
  createdAt DateTime @default(now()) @map(name: "created_at")
  boardId   String   @map(name: "board_id")
  actorId   String?  @map(name: "actor_id")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([boardId, id])
  @@index([actorId])
  @@map(name: "board_events")
}
